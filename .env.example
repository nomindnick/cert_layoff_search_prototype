# .env.example — copy to .env and fill in. NEVER commit real secrets.
# Every variable maps to a field in backend/config.py (env-overridable).

# --- Environment ---
# development | production. "development" enables permissive CORS and the "demo" token.
ENV=development

# --- Local artifact paths (offline build writes these; defaults are fine for local dev) ---
INDEX_DIR=build/output/indexes
RECORDS_PATH=build/output/records.json
METADATA_PATH=build/output/metadata.json

# --- Cloudflare R2 (leave blank for local dev to load from the paths above) ---
# When set AND local files are missing, the backend downloads indexes/*.pkl + records.json
# + metadata.json from R2_INDEX_BASE_URL at startup. R2_DOC_BASE_URL is the base for
# source PDFs (docs/{year}/{stem}.pdf), embedded in served records as pdf_url.
R2_INDEX_BASE_URL=
R2_DOC_BASE_URL=

# --- Analytics / events database ---
# sqlite for local dev; Railway injects a postgresql:// URL in production.
DATABASE_URL=sqlite:///./events.db

# --- Access tokens (magic links) ---
# Format: "token:Display Name,token2:Name 2". Each token is auth + analytics user id.
# The default "demo" token works out of the box in development.
ACCESS_TOKENS=demo:Demo User

# --- Embeddings (serve-time) ---
# none = BM25-only (v1 default; no torch needed). arctic | openai enable hybrid search,
# but ONLY work when the indexes were built WITH embeddings (build --embed).
EMBED_BACKEND=none

# Required only when EMBED_BACKEND=openai.
OPENAI_API_KEY=
